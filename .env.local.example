# Supabase — required for Auth, DB, Storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Vitest / Playwright E2E Test Accounts (only needed for local test runs)
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=AdminPassword123!
# TEST_MANAGER_EMAIL=manager@example.com
# TEST_MANAGER_PASSWORD=ManagerPassword123!
# TEST_AGENTUR_EMAIL=agentur@example.com
# TEST_AGENTUR_PASSWORD=AgenturPassword123!

# Ollama KI-Bewertung (PROJ-4)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Slack-Integration (PROJ-8)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
